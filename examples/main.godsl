package main

import "log"
import "github.com/sviridovkonstantin42/godsl/examples/utils"

func main(){
    try{
        //@errcheck
        a, err:=utils.FunctionWithError()
        log.Println("computed a...")

        //@errcheck
        b, err:=utils.FunctionWithError()
        log.Println("computed b...")

        //@errcheck
        c, err:=utils.FunctionWithError()
        log.Println("computed c...")
        log.Println(a,b,c)
    } catch {
        log.Println(err)
    }
}
